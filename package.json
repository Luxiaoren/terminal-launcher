{
  "name": "foldim",
  "version": "1.0.0",
  "description": "轻量级 Windows 桌面终端管理工具",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack": "electron-builder --win zip"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.3.0",
    "fast-check": "^3.15.0",
    "typescript": "^5.3.3",
    "vite": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.0.0"
  },
  "build": {
    "appId": "com.foldim.app",
    "productName": "Foldim",
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ]
    },
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**",
      "!node_modules/**/*.md"
    ],
    "extraResources": [
      {
        "from": "config",
        "to": "config",
        "filter": ["**/*"]
      }
    ],
    "npmRebuild": true
  }
}
